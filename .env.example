# Це зразок. Для бекенду використовуйте `backend/.env`.
#
# Backend:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/tastyhub
# JWT_SECRET_KEY=change_me
# CORS_ORIGINS=http://localhost:3000
#
# --- Підтвердження email: Gmail (локальна розробка, SMTP) ---
# 1. Увімкніть 2FA в Google Account
# 2. Security → App passwords → створіть пароль для TastyHub
# 3. EMAIL_FROM / SMTP_FROM — адреса відправника
#
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# EMAIL_FROM=TastyHub <you@gmail.com>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# FRONTEND_URL=http://localhost:3000
#
# Альтернатива Gmail (порт 465): SMTP_PORT=465, SMTP_USE_TLS=false, SMTP_USE_SSL=true
#
# --- Підтвердження email: Brevo (production на Render free tier) ---
# Render блокує SMTP (порти 587/465). Brevo працює через HTTP API.
# 1. Зареєструйтесь на https://www.brevo.com
# 2. Settings → Senders — додайте та підтвердьте Gmail
# 3. SMTP & API → API Keys — створіть ключ
#
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-your_api_key
# EMAIL_FROM=TastyHub <you@gmail.com>
# FRONTEND_URL=https://your-app.vercel.app
#
# --- Підтвердження email: Mailtrap (лише пісочниця, для розробки) ---
# EMAIL_PROVIDER=smtp
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=your_mailtrap_user
# SMTP_PASSWORD=your_mailtrap_password
# EMAIL_FROM=TastyHub <noreply@tastyhub.local>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# FRONTEND_URL=http://localhost:3000
#
# Опційно: локальні завантаження (без Cloudinary)
# UPLOAD_DIR=../uploads
# MAX_UPLOAD_MB=5
#
# --- Production (Render): постійне сховище зображень Cloudinary ---
# На Render локальна папка uploads/ очищується після кожного деплою.
# Зареєструйтесь на https://cloudinary.com і додайте на Render:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Frontend (опційно, файл `frontend/.env`):
# REACT_APP_API_URL=http://127.0.0.1:5000/api
