# Це зразок. Для бекенду використовуйте `backend/.env`.
#
# Backend:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/tastyhub
# JWT_SECRET_KEY=change_me
# CORS_ORIGINS=http://localhost:3000
#
# --- Підтвердження email: Gmail (реальна пошта) ---
# 1. Увімкніть 2FA в Google Account
# 2. Security → App passwords → створіть пароль для TastyHub
# 3. SMTP_FROM має містити ту саму Gmail-адресу, що й SMTP_USER
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# SMTP_FROM=TastyHub <you@gmail.com>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# FRONTEND_URL=http://localhost:3000
#
# Альтернатива Gmail (порт 465): SMTP_PORT=465, SMTP_USE_TLS=false, SMTP_USE_SSL=true
#
# --- Підтвердження email: Mailtrap (лише пісочниця, для розробки) ---
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=your_mailtrap_user
# SMTP_PASSWORD=your_mailtrap_password
# SMTP_FROM=TastyHub <noreply@tastyhub.local>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# FRONTEND_URL=http://localhost:3000
#
# Frontend (опційно, файл `frontend/.env`):
# REACT_APP_API_URL=http://127.0.0.1:5000/api
